---
// Aankondigingsbalk per seizoen. Eén tekst per seizoen, één zichtbaar via CSS.
// CTA opent de Zenchef-modal (data-zenchef-open).
---

<div class="season-bar" data-season-bar role="region" aria-label="Aankondigingen">
  <div class="season-bar__inner">
    <span class="season-bar__dot" aria-hidden="true"></span>
    <span data-season-text="lente">Het terras gaat weer open vanaf 1 april.</span>
    <span data-season-text="zomer">Zomeravonden aan de Veste. Reserveer je terrastafel.</span>
    <span data-season-text="herfst">Het herfstmenu staat op de kaart, met wild en knolgewassen.</span>
    <span data-season-text="winter">Kerstmenu op 24 en 25 december. Reserveer tijdig.</span>
    <button type="button" class="season-bar__cta" data-zenchef-open>Reserveren</button>
  </div>
  <button type="button" class="season-bar__close" data-season-bar-close aria-label="Sluit aankondiging">
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <line x1="6" y1="6" x2="18" y2="18"/>
      <line x1="6" y1="18" x2="18" y2="6"/>
    </svg>
  </button>
</div>
