---
import fs from "node:fs";
import path from "node:path";

interface Props {
  src?: string;
  alt?: string;
  aspect?: string;
  class?: string;
}
const { src, alt = "", aspect = "4 / 5", class: extra = "" } = Astro.props;

// Als er een winterversie bestaat op /photos/winter/<basename>, maak de foto
// seizoens-wisselend (zomer-bron + winter-variant, wisselt via [data-season]).
let winterSrc: string | undefined;
if (src) {
  const base = src.split("/").pop();
  const candidate = `/photos/winter/${base}`;
  if (fs.existsSync(path.join(process.cwd(), "public", candidate.slice(1)))) {
    winterSrc = candidate;
  }
}
---

<div class={`photo ${extra}`} style={`aspect-ratio: ${aspect};`}>
  {src && !winterSrc && <img src={src} alt={alt} loading="lazy" decoding="async" />}
  {src && winterSrc && (
    <Fragment>
      <img data-season-img="zomer" src={src} alt={alt} loading="lazy" decoding="async" />
      <img data-season-img="winter" src={winterSrc} alt={alt} loading="lazy" decoding="async" />
    </Fragment>
  )}
</div>
