---
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import ZenchefModal from "../components/ZenchefModal.astro";
import SeasonBar from "../components/SeasonBar.astro";
import SeasonSwitch from "../components/SeasonSwitch.astro";
import Analytics from "@vercel/analytics/astro";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}
const {
  title = "Xuma Goes | Wereldse smaken aan de Veste",
  description = "Restaurant Xuma in Goes serveert wereldse smaken op basis van Zeeuwse producten met een creatieve twist. Aan de Dam met uitzicht over de Veste.",
  ogImage = "/photos/terras-veste.webp",
} = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://demo-xuma.vercel.app").href;
const ogImageAbs = new URL(ogImage, Astro.site ?? "https://demo-xuma.vercel.app").href;
---

<!doctype html>
<html lang="nl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#221710" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png" />

    <!-- Open Graph / social -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Xuma Goes" />
    <meta property="og:locale" content="nl_NL" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImageAbs} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageAbs} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT@0,9..144,300..600,30..100;1,9..144,300..600,30..100&family=Inter:wght@400;500;600&display=swap"
    />

    <ClientRouter />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-topbar">
      <SeasonBar />
      <Header />
    </div>
    <main>
      <slot />
    </main>
    <Footer />
    <ZenchefModal />
    <SeasonSwitch />
    <button type="button" class="sticky-reserve" data-zenchef-open aria-label="Reserveer een tafel">
      <span class="sticky-reserve__dot" aria-hidden="true"></span>
      <span>Reserveren</span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M5 12h14"/><path d="m13 6 6 6-6 6"/>
      </svg>
    </button>

    <!-- Subtiele reserveer-nudge (schuift rechtsonder in i.p.v. midden-scherm popup) -->
    <div class="reserve-nudge" data-reserve-nudge hidden role="dialog" aria-label="Reserveren">
      <button type="button" class="reserve-nudge__close" data-reserve-nudge-close aria-label="Sluiten">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="6" y1="6" x2="18" y2="18"/><line x1="6" y1="18" x2="18" y2="6"/></svg>
      </button>
      <div class="reserve-nudge__eyebrow">Reserveren</div>
      <p class="reserve-nudge__text">Zin om langs te komen? Reserveer eenvoudig je tafel aan de Veste.</p>
      <button type="button" class="btn btn-primary reserve-nudge__cta" data-zenchef-open data-reserve-nudge-cta>Tafel reserveren</button>
    </div>

    <Analytics />

    <script is:inline>
      // Vroege detectie (voorkomt FOUC); herdraait bij elke view-transitie.
      (function () {
        var html = document.documentElement;
        var stored = localStorage.getItem("xuma-season");
        var seasons = ["zomer", "winter"];
        var season = stored && seasons.indexOf(stored) >= 0 ? stored : null;
        if (!season) {
          var m = new Date().getMonth();
          season = m >= 3 && m <= 8 ? "zomer" : "winter";
        }
        html.setAttribute("data-season", season);
        // Demo-intro (alleen op home) tonen bij eerste bezoek, anders direct verbergen.
        var introEl = document.getElementById("demo-intro");
        var dismissed = sessionStorage.getItem("xuma-intro-dismissed") === "1";
        if (document.body) {
          if (introEl && !dismissed) {
            document.body.classList.add("has-intro");
          } else {
            document.body.classList.remove("has-intro");
            if (introEl) introEl.style.display = "none";
          }
        }
      })();
    </script>

    <script>
      type Season = "zomer" | "winter";
      const SEASON_LABELS: Record<Season, string> = { zomer: "Zomer", winter: "Winter" };
      const isSeason = (v: string | null): v is Season => v === "zomer" || v === "winter";

      // ── Helpers (queryen de live DOM, dus veilig na een view-transitie) ──
      function applySeasonUI() {
        const html = document.documentElement;
        let s = html.getAttribute("data-season");
        if (!isSeason(s)) { s = "zomer"; html.setAttribute("data-season", s); }
        const cur = document.querySelector("[data-season-switch-current]");
        if (cur) cur.textContent = SEASON_LABELS[s].toLowerCase();
        document.querySelectorAll<HTMLElement>("[data-season-option]").forEach((opt) =>
          opt.setAttribute("aria-current", opt.dataset.seasonOption === s ? "true" : "false")
        );
      }
      function setSeason(s: Season) {
        document.documentElement.setAttribute("data-season", s);
        localStorage.setItem("xuma-season", s);
        applySeasonUI();
        const bar = document.querySelector<HTMLElement>("[data-season-bar]");
        if (bar) {
          bar.classList.remove("is-hidden");
          sessionStorage.removeItem("xuma-season-bar-dismissed");
        }
      }

      const overlay = () => document.querySelector<HTMLElement>("[data-zenchef-overlay]");
      function openModal() {
        const ov = overlay();
        if (!ov) return;
        sessionStorage.setItem("xuma-zenchef-seen", "1");
        ov.hidden = false;
        requestAnimationFrame(() => requestAnimationFrame(() => ov.classList.add("is-open")));
        document.body.style.overflow = "hidden";
      }
      function closeModal() {
        const ov = overlay();
        if (!ov) return;
        ov.classList.remove("is-open");
        document.body.style.overflow = "";
        sessionStorage.setItem("xuma-zenchef-seen", "1");
        setTimeout(() => {
          const o = overlay();
          if (o && !o.classList.contains("is-open")) o.hidden = true;
        }, 260);
      }
      function maybeAutoOpenZenchef() {
        if (sessionStorage.getItem("xuma-zenchef-seen") === "1") return;
        const nudge = document.querySelector<HTMLElement>("[data-reserve-nudge]");
        if (!nudge) return;
        setTimeout(() => {
          if (sessionStorage.getItem("xuma-zenchef-seen") === "1") return;
          sessionStorage.setItem("xuma-zenchef-seen", "1");
          nudge.hidden = false;
          document.body.classList.add("reserve-nudge-open");
          requestAnimationFrame(() => requestAnimationFrame(() => nudge.classList.add("is-open")));
        }, 2200);
      }

      // ── Eenmalige document/window-listeners (delegated, queryen live) ──
      const updateChrome = () => {
        const header = document.querySelector<HTMLElement>("[data-header]");
        if (header) header.classList.toggle("is-scrolled", window.scrollY > 8);
        const topbar = document.querySelector<HTMLElement>(".site-topbar");
        if (topbar) {
          document.documentElement.style.setProperty(
            "--topbar-h",
            `${Math.ceil(topbar.getBoundingClientRect().height)}px`
          );
        }
      };
      window.addEventListener("scroll", updateChrome, { passive: true });
      window.addEventListener("resize", updateChrome);
      document.addEventListener("keydown", (e) => {
        const ov = overlay();
        if (e.key === "Escape" && ov && ov.classList.contains("is-open")) closeModal();
      });
      document.addEventListener("click", (e) => {
        const ov = overlay();
        if (ov && e.target === ov) closeModal();
        const sw = document.querySelector<HTMLElement>("[data-season-switch]");
        if (sw && !sw.contains(e.target as Node)) {
          sw.classList.remove("is-open");
          document.querySelector("[data-season-switch-toggle]")?.setAttribute("aria-expanded", "false");
        }
      });

      // ── Per-pagina setup: draait bij eerste load én na elke view-transitie ──
      function setupPage() {
        applySeasonUI();
        updateChrome();

        // Reveal-on-scroll
        const obs = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                obs.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -60px 0px" }
        );
        document.querySelectorAll("[data-reveal]").forEach((el) => obs.observe(el));

        // Demo-intro (alleen op home aanwezig)
        const intro = document.querySelector<HTMLElement>("[data-intro]");
        const introBtn = document.querySelector<HTMLButtonElement>("[data-intro-dismiss]");
        if (intro) {
          if (sessionStorage.getItem("xuma-intro-dismissed") === "1") {
            intro.remove();
            document.body.classList.remove("has-intro");
          } else if (introBtn) {
            document.body.classList.add("has-intro");
            document.body.style.overflow = "hidden";
            introBtn.addEventListener("click", () => {
              intro.classList.add("is-leaving");
              document.body.style.overflow = "";
              document.body.classList.remove("has-intro");
              sessionStorage.setItem("xuma-intro-dismissed", "1");
              setTimeout(() => {
                intro.remove();
                maybeAutoOpenZenchef();
              }, 500);
            });
          }
        }

        // Mobiele nav
        const navToggles = document.querySelectorAll<HTMLButtonElement>("[data-nav-toggle]");
        const navPanel = document.querySelector<HTMLElement>("[data-nav-panel]");
        if (navToggles.length && navPanel) {
          navToggles.forEach((btn) =>
            btn.addEventListener("click", () => {
              const open = navPanel.classList.toggle("is-open");
              navToggles.forEach((b) => b.setAttribute("aria-expanded", String(open)));
              document.body.style.overflow = open ? "hidden" : "";
            })
          );
          navPanel.querySelectorAll("a").forEach((a) =>
            a.addEventListener("click", () => {
              navPanel.classList.remove("is-open");
              navToggles.forEach((b) => b.setAttribute("aria-expanded", "false"));
              document.body.style.overflow = "";
            })
          );
        }

        // Zenchef open/close knoppen
        document.querySelectorAll<HTMLButtonElement>("[data-zenchef-open]").forEach((b) =>
          b.addEventListener("click", openModal)
        );
        document.querySelectorAll<HTMLButtonElement>("[data-zenchef-close]").forEach((b) =>
          b.addEventListener("click", closeModal)
        );

        // Aankondigingsbalk dismiss
        const bar = document.querySelector<HTMLElement>("[data-season-bar]");
        const barClose = document.querySelector<HTMLButtonElement>("[data-season-bar-close]");
        if (bar && barClose) {
          if (sessionStorage.getItem("xuma-season-bar-dismissed") === "1") bar.classList.add("is-hidden");
          barClose.addEventListener("click", () => {
            bar.classList.add("is-hidden");
            sessionStorage.setItem("xuma-season-bar-dismissed", "1");
          });
        }

        // Seizoens-switcher
        const sw = document.querySelector<HTMLElement>("[data-season-switch]");
        const swToggle = document.querySelector<HTMLButtonElement>("[data-season-switch-toggle]");
        if (sw && swToggle) {
          swToggle.addEventListener("click", (e) => {
            e.stopPropagation();
            const open = sw.classList.toggle("is-open");
            swToggle.setAttribute("aria-expanded", String(open));
          });
        }
        document.querySelectorAll<HTMLButtonElement>("[data-season-option]").forEach((opt) =>
          opt.addEventListener("click", () => {
            const v = opt.dataset.seasonOption ?? null;
            if (isSeason(v)) setSeason(v);
            sw?.classList.remove("is-open");
            swToggle?.setAttribute("aria-expanded", "false");
          })
        );

        // Open/gesloten-indicator (dagelijks 11:00 tot 23:00)
        const statusEl = document.querySelector<HTMLElement>("[data-open-status]");
        const statusText = document.querySelector<HTMLElement>("[data-open-status-text]");
        if (statusEl && statusText) {
          const h = new Date().getHours();
          const open = h >= 11 && h < 23;
          statusEl.setAttribute("data-open", open ? "ja" : "nee");
          statusText.textContent = open
            ? "Nu open, tot 23:00"
            : h < 11
            ? "Gesloten, opent om 11:00"
            : "Gesloten, tot morgen 11:00";
        }

        // Nieuwsbrief (demo, geen backend)
        const news = document.querySelector<HTMLFormElement>("[data-newsletter]");
        const newsDone = document.querySelector<HTMLElement>("[data-newsletter-done]");
        if (news) {
          news.addEventListener("submit", (e) => {
            e.preventDefault();
            news.hidden = true;
            if (newsDone) newsDone.hidden = false;
          });
        }

        // Reserveer-nudge sluiten
        const nudge = document.querySelector<HTMLElement>("[data-reserve-nudge]");
        const hideNudge = () => {
          if (!nudge) return;
          nudge.classList.remove("is-open");
          document.body.classList.remove("reserve-nudge-open");
          setTimeout(() => {
            if (nudge && !nudge.classList.contains("is-open")) nudge.hidden = true;
          }, 320);
        };
        document
          .querySelectorAll<HTMLButtonElement>("[data-reserve-nudge-close], [data-reserve-nudge-cta]")
          .forEach((b) => b.addEventListener("click", hideNudge));
      }

      document.addEventListener("astro:page-load", setupPage);
    </script>
  </body>
</html>
