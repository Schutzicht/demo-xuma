        <Photo src="/photos/eethoek-daglicht.webp" alt="Lichte eethoek met daglicht aan de Veste" aspect="4 / 5"/>
      </div>
      <div data-reveal>
        <span class="eyebrow">
          <span data-season-text="zomer">High tea bij Xuma</span>
          <span data-season-text="winter">Winter high tea bij Xuma</span>
        </span>
        <h2 class="font-display text-4xl sm:text-5xl mt-3 leading-[1.05]">
          <span data-season-text="zomer">Een middag aan de Veste.</span>
          <span data-season-text="winter">Warm de winter door.</span>
        </h2>
        <p class="mt-5 text-base leading-relaxed text-[rgba(34,23,16,0.78)] max-w-[55ch]">
