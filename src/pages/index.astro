          <li class="flex items-baseline gap-3">
            <span class="font-display text-lg text-[var(--color-copper-dark)]">03</span>
            <span><strong class="font-medium">Dessert.</strong> <span data-season-text="zomer">Dessert Xuma, signature finale</span><span data-season-text="winter">Warme chocolademoelleux met karamel</span></span>
          </li>
        </ul>
        <div class="mt-8 flex flex-wrap items-center gap-5">
          <div>
            <div class="text-xs uppercase tracking-[0.18em] text-[var(--color-copper-dark)]">Vanaf</div>
            <div class="font-display text-4xl">&euro; <span data-season-text="zomer">59,50</span><span data-season-text="winter">64,50</span></div>
          </div>
